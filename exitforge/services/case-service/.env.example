# =============================================
# case-service environment configuration
# =============================================
# Copy this file to .env for local development:
#   cp .env.example .env
# Then fill in real values below.
# NEVER commit .env to version control.
# =============================================

# Runtime environment
NODE_ENV=development            # development | staging | production

# HTTP
PORT=3001                       # Port this service listens on

# ---- Database ----
# PostgreSQL connection string.
# Local: provided by docker-compose.yml
# Production: set via AWS Parameter Store /exitforge/prod/case-service/DATABASE_URL
DATABASE_URL=postgresql://exitforge:exitforge_dev@localhost:5432/exitforge

# ---- Kafka ----
# Comma-separated list of broker addresses
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=case-service
KAFKA_GROUP_ID=case-service-group

# ---- Authentication (Clerk) ----
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ---- ML Service ----
# Internal URL of the ml-service (used for qualification scoring)
ML_SERVICE_URL=http://localhost:8001
