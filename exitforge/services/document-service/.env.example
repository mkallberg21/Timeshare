# =============================================
# document-service environment configuration
# =============================================

APP_ENV=development

PORT=3007

# ---- MongoDB ----
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=exitforge_documents

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092

# ---- AWS S3 ----
# In production, use IRSA (no access keys needed)
AWS_REGION=us-east-1
AWS_S3_BUCKET=exitforge-documents-dev
AWS_ACCESS_KEY_ID=your_local_access_key
AWS_SECRET_ACCESS_KEY=your_local_secret_key

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-your_key_here
