# =============================================
# payment-service environment configuration
# =============================================

NODE_ENV=development

PORT=3005

# ---- Database ----
DATABASE_URL=postgresql://exitforge:exitforge_dev@localhost:5432/exitforge

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=payment-service
KAFKA_GROUP_ID=payment-service-group

# ---- Authentication ----
CLERK_SECRET_KEY=sk_test_your_key_here

# ---- Stripe ----
# Test keys from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_key
# Get webhook secret from: stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---- Escrow.com ----
# Sandbox: https://www.escrow.com/api/docs
ESCROW_API_KEY=your_escrow_api_key
# Use sandbox URL for development:
ESCROW_API_BASE_URL=https://api.sandbox.escrow.com/2017-09-01
