# =============================================
# ai-orchestrator environment configuration
# =============================================

APP_ENV=development

PORT=8000

# ---- Anthropic ----
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=ai-orchestrator-group
KAFKA_TOPIC_CASE_EVENTS=case.events

# ---- Redis (LangGraph checkpoints) ----
# Local: provided by docker-compose.yml
REDIS_URL=redis://localhost:6379

# ---- case-service ----
# Used to update case status after graph transitions
CASE_SERVICE_URL=http://localhost:3001
