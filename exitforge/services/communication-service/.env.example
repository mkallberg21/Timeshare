# =============================================
# communication-service environment configuration
# =============================================

NODE_ENV=development

PORT=3004

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=communication-service
KAFKA_GROUP_ID=communication-service-group

CLERK_SECRET_KEY=sk_test_your_key_here

# ---- Email (SendGrid) ----
# Get from: https://app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.your_api_key
SENDGRID_FROM_EMAIL=noreply@exitforge.com

# ---- SMS (Twilio) — optional ----
TWILIO_ACCOUNT_SID=ACyour_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567
