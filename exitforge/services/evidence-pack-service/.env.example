# Evidence Pack Service — Environment Variables

SERVICE_NAME=evidence-pack-service
PORT=8006

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4000

# AWS / S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=exitforge-documents

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=evidence_packs

# Downstream services
CASE_SERVICE_URL=http://case-service:4000
DOCUMENT_SERVICE_URL=http://document-service:8002
RESORT_INTELLIGENCE_URL=http://resort-intelligence:8003

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=evidence-pack-service
KAFKA_CLIENT_ID=evidence-pack-service

# SendGrid
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=legal-ops@exitforge.com
SENDGRID_FROM_NAME=ExitForge Legal Operations

# Pre-signed URL TTL (seconds) — default 7 days
PRESIGNED_URL_EXPIRY_SECONDS=604800

# Observability (optional)
DD_SERVICE=evidence-pack-service
DD_ENV=production
OTLP_ENDPOINT=http://otel-collector:4318
